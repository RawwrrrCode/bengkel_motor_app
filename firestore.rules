rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function ownsBengkel(bengkelId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/bengkels/$(bengkelId)).data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /bengkels/{bengkelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      match /spareparts/{sparepartId} {
        allow read: if isSignedIn();
        allow write: if ownsBengkel(bengkelId);
      }

      match /jasa/{jasaId} {
        allow read: if isSignedIn();
        allow write: if ownsBengkel(bengkelId);
      }
    }

    match /serviceRequests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.customerUid == request.auth.uid || ownsBengkel(resource.data.bengkelId));
      allow create: if isSignedIn() && request.resource.data.customerUid == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.customerUid == request.auth.uid || ownsBengkel(resource.data.bengkelId));
    }
  }
}
